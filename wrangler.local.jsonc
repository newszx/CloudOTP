{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudotp-local",
  "main": "src/index.js",
  "compatibility_date": "2026-07-10",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cloudotp-db",
      "database_id": "local-cloudotp-db",
      "migrations_dir": "migrations"
    }
  ]
}
