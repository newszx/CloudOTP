{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudotp",
  "main": "src/index.js",
  "compatibility_date": "2026-07-10",
  "workers_dev": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cloudotp-db",
      "database_id": "",
      "migrations_dir": "migrations"
    }
  ],
  "observability": {
    "enabled": true
  }
}
